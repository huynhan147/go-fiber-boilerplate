APP_NAME=myapp
APP_ENV=local
APP_PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=myapp_db
DB_USERNAME=root
DB_PASSWORD=secret
DB_CHARSET=utf8mb4

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRE_HOURS=24

# External services
TRANSACTION_SERVICE_URL=http://project-a.internal
TRANSACTION_SERVICE_API_KEY=secret-key-a

SHIPPING_SERVICE_URL=http://project-b.internal
SHIPPING_SERVICE_API_KEY=secret-key-b

LOG_DIR=storage/logs
